</BaseLayout>

<style>
  .legal {
    padding-top: 140px;
    padding-bottom: 80px;
  }

  .legal h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 32px;
  }

  .params-table {
    border-collapse: collapse;
    margin-bottom: 40px;
    width: 100%;
    max-width: 700px;
  }

  .params-table td {
    padding: 10px 16px;
    border: 1px solid var(--border);
    font-size: 0.95rem;
    color: var(--text-muted);
    vertical-align: top;
  }

  .params-table td:first-child {
    width: 160px;
    white-space: nowrap;
    color: var(--text-heading);
  }

  .legal-body {
    max-width: 700px;
  }

  .legal-body h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-top: 40px;
    margin-bottom: 16px;
  }

  .legal-body h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 24px;
    margin-bottom: 12px;
  }

  .legal-body p {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .legal-body ul, .legal-body ol {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.8;
    padding-left: 24px;
    margin-bottom: 16px;
  }

  .legal-body li {
    margin-bottom: 6px;
  }

  .legal-caps {
    font-size: 0.9rem !important;
    letter-spacing: 0.01em;
  }

  .legal-small {
    font-size: 0.85rem !important;
    opacity: 0.7;
  }

  .legal-links {
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .legal-links p {
    margin-bottom: 8px;
  }
</style>

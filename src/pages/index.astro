<script is:inline>
  function initAISparkle() {
    var base  = document.getElementById('ai-base');
    var trail = document.getElementById('ai-trail');
    var lead  = document.getElementById('ai-lead');
    if (!base || !trail || !lead) return;

    var bbox   = base.getBBox();
    var n      = base.textContent.trim().length;
    var avgW   = bbox.width / n;
    var h      = bbox.height;
    var pathLen = Math.round(2 * (avgW + h) * n * 0.85);
    var cycle  = Math.round(pathLen * 1.02);
    var dur    = 7;

    trail.style.strokeDasharray = '65 ' + (cycle - 65);
    trail.style.setProperty('--ai-cycle', -cycle + 'px');
    trail.style.setProperty('--ai-dur', dur + 's');

    lead.style.strokeDasharray = '14 ' + (cycle - 14);
    lead.style.setProperty('--ai-cycle', -cycle + 'px');
    lead.style.setProperty('--ai-dur', dur + 's');
  }

  if (document.fonts) {
    document.fonts.ready.then(initAISparkle);
  } else {
    window.addEventListener('load', initAISparkle);
  }
</script>
